{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "{{NEXT_PUBLIC_API_URL}}/api/:path*"
    },
    {
      "source": "/health",
      "destination": "{{NEXT_PUBLIC_API_URL}}/health"
    }
  ]
}
