# ============================================================
# TrendMuse Environment Variables
# ============================================================

# ---- Backend (.env in /backend/) ----

# GrsAI API Key for Nano Banana image generation
# Get one at https://grsai.com
GRSAI_API_KEY=sk-your-key-here

# GrsAI endpoint (use grsai.dakka.com.cn for China direct)
GRSAI_API_BASE=https://api.grsai.com

# Model: nano-banana-fast (cheap) or nano-banana-pro (better quality)
GRSAI_MODEL=nano-banana-fast

# Set to false when API keys are configured
DEMO_MODE=false
DEBUG=false

# ---- Frontend (.env.local in /frontend/) ----

# Backend URL for Next.js rewrites (used in next.config.js)
# Local dev: http://localhost:8000
# Production: https://your-backend.railway.app (or wherever you deploy)
NEXT_PUBLIC_API_URL=http://localhost:8000
